
import turtle
import random
import math




wn = turtle.Screen()
wn.setup(900, 900)
wn.bgcolor("black")
wn.tracer(0)




bg = turtle.Turtle()
bg.hideturtle()
bg.speed(0)
bg.penup()




def draw_star(x, y, size):
    bg.goto(x, y)
    bg.setheading(0)
    bg.pendown()
    bg.color("cyan")
    bg.pensize(1)
    for _ in range(8):
        bg.forward(size)
        bg.backward(size)
        bg.left(45)
    bg.penup()
    bg.goto(x, y)
    bg.dot(2, "white")




for i in range(350):
    x = random.randint(-430, 430)
    y = random.randint(-430, 430)
    if random.random() < 0.85:
        bg.goto(x, y)
        bg.color("skyblue")
        bg.dot(1)
    else:
        draw_star(x, y, random.randint(2, 4))




def draw_circle_on(t, x, y, radius, color):
    t.goto(x, y - radius)
    t.setheading(0)
    t.pendown()
    t.color(color)
    t.begin_fill()
    t.circle(radius)
    t.end_fill()
    t.penup()




def draw_orbit(radius):
    bg.goto(0, -radius)
    bg.setheading(0)
    bg.pendown()
    bg.color("dimgray")
    bg.pensize(1)
    bg.circle(radius)
    bg.penup()




draw_circle_on(bg, 0, 0, 75, "darkorange")
draw_circle_on(bg, 0, 0, 60, "orange")
draw_circle_on(bg, 0, 0, 45, "yellow")




ORBIT_RADII = [95, 135, 175, 215, 265, 305, 345, 385]
for r in ORBIT_RADII:
